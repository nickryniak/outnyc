# OutNYC — environment template.
#
# Copy this file to `.env` and fill in ONLY the keys you want to enable.
#   cp .env.example .env
#
# Every var is OPTIONAL. With none set, the app runs entirely on mock/seed
# data — onboarding, week view, availability, "Plan this day" (heuristic),
# reshuffle, bucket list, and settings all work with zero keys and no card.
#
# NOTE: any EXPO_PUBLIC_* value is bundled into the app and is therefore NOT
# secret. This is an accepted tradeoff for a single-user personal v1. For the
# LLM planner, prefer the secure Supabase edge-function path over a client key
# (see supabase/functions/planDay/). Restart `npx expo start` after editing.

# Ticketmaster Discovery API — live NYC events. Free, instant, no card.
# https://developer.ticketmaster.com/
EXPO_PUBLIC_TICKETMASTER_API_KEY=

# Google Gemini — optional live LLM day planning (free tier). No card.
# https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# Google Places API — live NYC restaurants/places. Requires a card.
# https://console.cloud.google.com/google/maps-apis
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Supabase (future swap; optional). Used for the secure edge-function planner.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
