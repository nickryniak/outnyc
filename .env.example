# OutNYC — copy to .env and fill in only what you want live (all optional).
# A missing/empty key means that source stays on curated seed data.
# NOTE: EXPO_PUBLIC_* values are bundled into the app and are NOT secret.

# Ticketmaster Discovery API (live events). Free, instant, no card.
EXPO_PUBLIC_TICKETMASTER_API_KEY=

# SeatGeek client id (second live event source: indie venues, sports, comedy). Free.
EXPO_PUBLIC_SEATGEEK_CLIENT_ID=

# Google Places API (live restaurants/bars with real ratings). Requires a card.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Gemini (reserved for a future client LLM-planner adapter; flag only today).
EXPO_PUBLIC_GEMINI_API_KEY=

# Supabase (future backend swap + secure edge-function LLM planning).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
