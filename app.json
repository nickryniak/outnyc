{
  "expo": {
    "name": "OutNYC",
    "slug": "outnyc",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "outnyc",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.outnyc.app"
    },
    "android": {
      "package": "com.outnyc.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B0F"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#E0613A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
